<view class="container">
  <view class="page-header">
    <text class="page-title">协作中心</text>
    <text class="page-desc">工单与消息</text>
  </view>

  <view class="collab-grid">
    <view class="collab-item" bindtap="goWorkOrder">
      <view class="icon-wrap">
        <image class="collab-icon-img" src="/assets/icons/svg/workorder.svg" mode="aspectFit" />
        <view class="badge" wx:if="{{workOrderCount > 0}}">{{workOrderCount}}</view>
      </view>
      <text class="collab-name">我的工单</text>
    </view>

    <view class="collab-item" bindtap="goMessages">
      <view class="icon-wrap">
        <image class="collab-icon-img" src="/assets/icons/svg/message.svg" mode="aspectFit" />
        <view class="badge" wx:if="{{messageCount > 0}}">{{messageCount}}</view>
      </view>
      <text class="collab-name">我的消息</text>
    </view>
  </view>
</view>
