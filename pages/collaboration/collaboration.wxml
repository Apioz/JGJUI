<view class="container">
  <view class="page-header">
    <text class="page-title">协作中心</text>
    <text class="page-desc">待办、工单与消息一站式管理</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goTodo">
      <view class="menu-icon todo">📋</view>
      <view class="menu-content">
        <text class="menu-name">我的待办</text>
        <text class="menu-desc">待处理事项与审批任务</text>
      </view>
      <view class="menu-right">
        <view class="badge" wx:if="{{todoCount > 0}}">{{todoCount}}</view>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goWorkOrder">
      <view class="menu-icon workorder">🔧</view>
      <view class="menu-content">
        <text class="menu-name">我的工单</text>
        <text class="menu-desc">报修、维保及巡检工单</text>
      </view>
      <view class="menu-right">
        <view class="badge" wx:if="{{workOrderCount > 0}}">{{workOrderCount}}</view>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goMessages">
      <view class="menu-icon message">💬</view>
      <view class="menu-content">
        <text class="menu-name">我的消息</text>
        <text class="menu-desc">系统通知与同事消息</text>
      </view>
      <view class="menu-right">
        <view class="badge" wx:if="{{messageCount > 0}}">{{messageCount}}</view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>
</view>
