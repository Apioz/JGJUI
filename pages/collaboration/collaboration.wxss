.page-header {
  padding: 40rpx 0 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

.collab-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 48rpx;
  max-width: 480rpx;
  margin: 40rpx auto 0;
  padding: 20rpx 0;
}

.collab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.collab-item .icon-wrap {
  margin-bottom: 16rpx;
}

.collab-item .badge {
  position: absolute;
  top: -4rpx;
  right: calc(50% - 56rpx);
}

.collab-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
