.page-header {
  padding: 40rpx 0 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-icon.todo { background: #FFF7E6; }
.menu-icon.workorder { background: #E6F7FF; }
.menu-icon.message { background: #F9F0FF; }

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.arrow {
  color: #CCC;
  font-size: 28rpx;
}
