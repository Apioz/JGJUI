<view class="profile-header" style="padding-top: {{statusBarHeight + 20}}px;">
  <view class="avatar-wrap">
    <view class="avatar">{{userProfile.name[0]}}</view>
  </view>
  <view class="profile-info">
    <text class="profile-name">{{userProfile.name}}</text>
    <text class="profile-role">{{userProfile.role}}</text>
  </view>
</view>

<view class="container">
  <view class="card info-card">
    <view class="info-row">
      <text class="info-label">所属项目园区</text>
      <text class="info-value">{{userProfile.project}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">所属部门</text>
      <text class="info-value">{{userProfile.department}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">工号</text>
      <text class="info-value">{{userProfile.employeeId}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">手机号</text>
      <text class="info-value">{{userProfile.phone}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goProfile">
      <view class="menu-icon">👤</view>
      <text class="menu-name">我的资料</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goContacts">
      <view class="menu-icon">📒</view>
      <text class="menu-name">通讯录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
