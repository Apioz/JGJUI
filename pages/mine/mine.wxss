.profile-header {
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #67B8FF 100%);
}

.avatar-wrap {
  margin-right: 28rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.profile-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.info-card {
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 400rpx;
  text-align: right;
}

.menu-list {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-icon-img {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  color: #CCC;
  font-size: 28rpx;
}
