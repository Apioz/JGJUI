.todo-list {
  padding-top: 16rpx;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.todo-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.todo-status.pending {
  background: #FF6B35;
}

.todo-status.done {
  background: #52C41A;
}

.todo-content {
  flex: 1;
}

.todo-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.todo-meta {
  display: flex;
  gap: 16rpx;
}

.todo-type {
  font-size: 24rpx;
  color: #4A90E2;
  background: #E6F4FF;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.todo-deadline {
  font-size: 24rpx;
  color: #999;
}
