.page-header {
  padding: 40rpx 0 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

.stats-card {
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

.stat-value.small {
  font-size: 32rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.module-card {
  margin-bottom: 20rpx;
}

.module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.module-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.trend {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.trend.up {
  color: #52C41A;
  background: #F6FFED;
}

.trend.down {
  color: #FF4D4F;
  background: #FFF1F0;
}

.module-total {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.total-label {
  font-size: 26rpx;
  color: #999;
}

.total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.module-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.module-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 28rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
