.profile-card {
  margin-top: 16rpx;
}

.profile-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.profile-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 420rpx;
  text-align: right;
}
