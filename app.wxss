page {
  background-color: #F5F6FA;
  font-family: -apple-system, BlinkMacCSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 0 24rpx 24rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title .more {
  font-size: 24rpx;
  font-weight: 400;
  color: #4A90E2;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.status-pass {
  color: #52C41A;
  font-weight: 500;
}

.status-fail {
  color: #FF4D4F;
  font-weight: 500;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}

.badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #FF4D4F;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}
