page {
  background-color: #F5F6FA;
  font-family: -apple-system, BlinkMacCSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 0 24rpx 24rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title .more {
  font-size: 24rpx;
  font-weight: 400;
  color: #4A90E2;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.status-pass {
  color: #52C41A;
  font-weight: 500;
}

.status-fail {
  color: #FF4D4F;
  font-weight: 500;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}

.badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #FF4D4F;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

/* Flat icon system */
.ui-icon-img { display: block; }

.icon-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-badge {
  position: absolute;
  top: -6rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #FF4D4F;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  z-index: 1;
}

.header-icon { width: 40rpx; height: 40rpx; }
.property-icon-img { width: 88rpx; height: 102rpx; }
.module-icon-img { width: 48rpx; height: 48rpx; }
.collab-icon-img { width: 72rpx; height: 72rpx; }
.menu-icon-img { width: 44rpx; height: 44rpx; }
.notify-icon-img { width: 44rpx; height: 44rpx; }
.asset-icon-img { width: 56rpx; height: 56rpx; }
